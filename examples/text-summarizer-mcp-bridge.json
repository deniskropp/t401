{
  "name": "text_summarizer",
  "description": "Generates concise, high-quality summaries from longer text while preserving key meaning and tone. Exposed as RTA-discoverable co-agent with coherence hooks.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "text": { "type": "string", "description": "The full text to summarize" },
      "max_length": { "type": "integer", "default": 150 },
      "style": { "type": "string", "enum": ["concise", "detailed", "bullet_points"], "default": "concise" }
    }
  },
  "meta": {
    "lineage": "gallery + gallery-skill-template + t401-mcp-bridge-templates",
    "rta": {
      "node_type": "external_coagent",
      "discoverable": true,
      "valence_aware": true,
      "coherence_hooks": ["flux", "drift", "valence"],
      "meta_dna_tags": ["gallery", "summarizer", "coagent"]
    },
    "coherence": {
      "emits": ["valence_delta", "coherence_note"],
      "supports_recalibration": true,
      "recommended_traversal": "ValenceContextDFS"
    },
    "valence": {
      "supports_valence_delta": true,
      "default_valence_impact": 0.05
    }
  }
}